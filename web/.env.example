# Data Lake (Trino)
TRINO_URL=http://localhost:8080
TRINO_USER=admin
TRINO_CATALOG=postgresql
TRINO_SCHEMA=public

# IA Local - Ollama (opcional, grátis, sem internet)
# Descomente as linhas do ollama no docker-compose.yml para ativar
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b

# IA Remota - OpenAI (opcional, fallback quando Ollama offline)
# Deixe vazio para usar apenas templates + Ollama
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
