# ═══════════════════════════════════════════════
# Juice Data Lake — Railway Environment Variables
# ═══════════════════════════════════════════════
# Referência de quais variáveis configurar em cada serviço no dashboard Railway.
# Nenhum segredo real vive neste arquivo — apenas nomes de variável e sintaxe
# de referência cruzada do Railway (${{ Service.VAR }}).

# ══════ PostgreSQL (Railway Managed) ══════
# Railway injeta automaticamente no serviço Postgres:
#   DATABASE_URL, DATABASE_PUBLIC_URL
#   PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE
# Não precisa configurar — é automático ao provisionar o serviço.

# ══════ Trino (Query Engine — serviço "Trino") ══════
# Build: docker/trino/railway/Dockerfile (root directory do serviço)
# Lê ${ENV:PGHOST} / ${ENV:PGPORT} / ${ENV:PGDATABASE} / ${ENV:PGUSER} / ${ENV:PGPASSWORD}
# diretamente do catalog/postgresql.properties via substituição nativa do Trino.
PGHOST=${{ Postgres.PGHOST }}
PGPORT=${{ Postgres.PGPORT }}
PGDATABASE=${{ Postgres.PGDATABASE }}
PGUSER=${{ Postgres.PGUSER }}
PGPASSWORD=${{ Postgres.PGPASSWORD }}

# ══════ Next.js App (serviço "web") ══════
NODE_ENV=production
PORT=3000

# Migração roda contra o Postgres gerenciado
DATABASE_URL=${{ Postgres.DATABASE_URL }}

# Trino interno (rede privada Railway)
TRINO_URL=http://${{ Trino.RAILWAY_PRIVATE_DOMAIN }}:8080
TRINO_USER=admin
TRINO_CATALOG=postgresql
TRINO_SCHEMA=public

# ══════ IA — Templates only (decisão do demo) ══════
# Não configurar OLLAMA_URL/OLLAMA_MODEL nem OPENAI_API_KEY.
# O chat cai automaticamente no engine de templates quando essas
# variáveis não existem — suficiente para a demonstração ao cliente.
